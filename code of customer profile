                    Swal.fire(e.message);
                }
            });
        });

        let order_verify = 1;
        document.getElementById("verify_order").addEventListener("click", function(e) {
            if (order_verify) {
                Swal.fire(
                    'Already Verified',
                    '',
                    'success'
                )
                return false;
            }

            $(this).html('<i class="fa fa-spinner" aria-hidden="true"></i> Verifying...');
            $.get("https://dash.railrestro.com/admin/orders/verify/5222368", (e) => {
                if (e.success) {
                    order_verify = 1;
                    $(this).html('<img src="/img/check-mark.png" /> Verified');
                    // location.reload();
                } else {
                    $(this).html('<button class="btn btn-block bg-green">Verify</button>');
                    Swal.fire(
                        e.message,
                        '',
                        'error'
                    )
                }
            });
        });
    </script>

    <style>

      .fa-cashback {
        background-color: black;
        color: white;
        padding: 1px 2px;
        border-radius: 5px;
      }
    </style>
</body>
