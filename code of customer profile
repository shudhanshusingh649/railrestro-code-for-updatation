        function backOrder(mobile) {
            fetch(`${APPURL}/admin/back-orders/${mobile}`).then(data => {
                return data.json();
            }).then(res => {
                var html = ''
                var due = ''
                var pay_status = ''
                var orderstatus = '{"1":"PLACED","2":"PENDING VENDOR CONFIRMATION","3":"PENDING CUSTOMER CONFIRMATION","4":"ACCEPTED","5":"DELIVERED","6":"REFUNDED","7":"CANCELED","8":"UNDELIVERED ","9":"MODIFIED"}';
                var orderstatus = JSON.parse(orderstatus);
                html +=
                    '<table class="table table-bordered table-consere"><thead><tr><th><a href="#">Id</a></th><th><a href="#">Customer Name</a></th> <th><a href="#">Train</a></th> <th><a href="#">Station</a></th> <th><a href="#">Order total</a></th> <th><a href="#">Payment</a></th> <th><a href="#">Status</a></th> <th><a href="#">Doj</a></th> <th><a href="#">Delivery</a></th> <th><a href="#">Created</a></th> <th class="actions">Actions</th></tr></thead><tbody>'
                if (res.status) {
                    res.details.forEach(function(orders) {
                        if (orders.pay_status == 'Success') {
                            pay_status =
                                '<br/> <small class="text-success" data-toggle="tooltip" data-placement="bottom" title="Successful"> <i class="glyphicon glyphicon-ok "></i>' +
                                orders.gateway + '</small>';
                        } else if (orders.pay_status == 'Awaiting') {
                            pay_status =
                                '<br/> <small class=" text-warning" data-toggle="tooltip" data-placement="bottom" title="Pending/Failed/Awaiting"> <i class="glyphicon glyphicon-exclamation-sign"></i>' +
                                orders.gateway + '</small>';
                        } else if (orders.pay_status == 'Pending') {
                            pay_status =
                                '<br/> <small class=" text-orange" data-toggle="tooltip" data-placement="bottom" title="Pending"> <i class="fa fa-refresh"></i>' +
                                orders.gateway + '</small>';
                        } else if (orders.pay_status == 'Failed') {
                            pay_status =
                                '<br/> <small class=" text-danger" data-toggle="tooltip" data-placement="bottom" title="Failed"> <i class="glyphicon glyphicon-exclamation-sign"></i>' +
                                orders.gateway + '</small>';
                        } else {
                            pay_status = ''
                        }
                        if (orders.payment == 'OTHER') {
                            due = ' <br/><small>Pre ' + orders.prepaid + '  Due ' + orders.due + '</small>';
                        } else {
                            due = ''
                        }
                        html += '<tr><td>' + orders.id + '</td><td>' + orders.name + '</td><td>' + orders
                            .train + '</td><td>' + orders.station + '</td><td>' + parseFloat(orders
                                .ordertotal).toFixed(2) + '</td><td>' + orders.payment + '' + pay_status +
                            '' + due + '</td><td> <span class="badge bg-' + res.color[orders.status] +
                            '">' + orderstatus[orders.status] + '</span></td><td>' + orders.doj +
                            '</td><td>' + getDateFormate(orders.dod_n) + '</td><td>' + getDateFormate(orders
                                .created) + '</td><td><a href="' + APPURL + '/admin/orders/view/' + orders
                            .id + '" class="btn btn-primary btn-xs"><i class="fa fa-eye"></i></a></td></tr>'
                    });
                } else {
                    html += ' <tr><td colspan="15">Customer Previous Orders Not Found</td></tr>'
                }
                html += '</tbody></table>'
                $('#back-order').html(html)
            });
        }

        function getDateFormate(date) {
            dod_n = new Date(date)
            dd = dod_n.getDate().toString().padStart(2, '0');
            mm = (1 + dod_n.getMonth()).toString().padStart(2, '0');
            yy = dod_n.getFullYear();
            hh = dod_n.getHours().toString().padStart(2, '0');
            mnt = dod_n.getMinutes().toString().padStart(2, '0');
            date_formate = dd + '-' + mm + '-' + yy + ' ' + hh + ':' + mnt;
            return date_formate
        }

